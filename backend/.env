# backend/.env (修正并清理后的版本)

# --- 总开关 ---
# 在这里选择你要使用的 API 提供商: "gemini" 或 "deepseek"
ACTIVE_LLM_PROVIDER="gemini"


# --- Google Gemini 配置 ---
# 请确保这里的密钥是你自己的有效密钥
GEMINI_API_KEY="YOUR_API_KEY"
# 使用稳定且有效的模型名称 gemini-2.5-pro
GEMINI_API_ENDPOINT="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-pro:generateContent"


# --- DeepSeek AI 配置 ---
# 当你需要使用 DeepSeek 时，请在这里填入你的密钥
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
DEEPSEEK_API_ENDPOINT="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"
